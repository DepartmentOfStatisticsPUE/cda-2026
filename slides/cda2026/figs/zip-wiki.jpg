        <mo stretchy="false">)</mo>
        <mo>=</mo>
        <mi>&#x03C0;<!-- π --></mi>
        <mo>+</mo>
        <mo stretchy="false">(</mo>
        <mn>1</mn>
        <mo>&#x2212;<!-- − --></mo>
        <mi>&#x03C0;<!-- π --></mi>
        <mo stretchy="false">)</mo>
