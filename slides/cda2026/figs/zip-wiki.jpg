        <mo>=</mo>
        <mn>0</mn>
        <mo stretchy="false">)</mo>
        <mo>&gt;</mo>
        <mn>0.5</mn>
      </mstyle>
    </mrow>
    <annotation encoding="application/x-tex">{\displaystyle p_{0}=\Pr(Y=0)&gt;0.5}</annotation>
  </semantics>
</math></span><img src="https://wikimedia.org/api/rest_v1/media/math/render/svg/06799c4487efdd4526cd7cdeca10934a6ec5fc91" class="mwe-math-fallback-image-inline" aria-hidden="true" style="vertical-align: -0.838ex; margin-left: -0.089ex; width:21.82ex; height:2.843ex;" alt="{\displaystyle p_{0}=\Pr(Y=0)&gt;0.5}"/></span>, then <span class="mwe-math-element"><span class="mwe-math-mathml-inline mwe-math-mathml-a11y" style="display: none;"><math xmlns="http://www.w3.org/1998/Math/MathML"  alttext="{\displaystyle |G(z)|\geqslant p_{0}-\sum \limits _{i=1}^{\infty }p_{i}=2p_{0}-1&gt;0}">
